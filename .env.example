# LLM provider configuration
OPENAI_API_KEY=
OPENAI_API_BASE=
MANAGER_MODEL=
AGENT_MODEL=

# MinerU API key for PDF-to-Markdown extraction.
# The application tries MinerU VLM first and falls back to local PyMuPDF when unset or failed.
MINERU_API_KEY=your_mineru_api_key_here

# Optional compatibility alias. Leave empty if using MINERU_API_KEY.
MINERU_API_TOKEN=

# Optional MinerU polling configuration.
MINERU_POLL_TIMEOUT_SECONDS=300
MINERU_POLL_INTERVAL_SECONDS=2

# Optional deterministic image-forensics precheck limits for local PDF mode.
# 0 disables that precheck branch; larger values increase runtime before CrewAI starts.
IMAGE_FORENSICS_MAX_SINGLE_IMAGES=12
IMAGE_FORENSICS_MAX_CROSS_IMAGES=200
IMAGE_FORENSICS_MAX_FEATURE_PANELS=80
